{
	"schemaVersion": 1,
	"id": "horyzon_bthi",
	"version": "${version}",
	"name": "Better Health Indicators",
	"description": "A mod displays the health of players on the Server! With many more features to come.",
	"authors": [
		"horyzonboi"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/horyzon_bthi/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.horyzon.BetterHealthIndicators"
		],
		"client": [
			"net.horyzon.client.BetterHealthIndicatorsClient"
		]
	},
	"mixins": [
		"horyzon_bthi.mixins.json",
		{
			"config": "horyzon_bthi.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}